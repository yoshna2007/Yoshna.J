#include<stdio.h>
int main(){
    char s1[100],s2[100];
    int i,count1=0,count2=0;

    scanf("%s",s1);
    scanf("%s",s2);

    while(s1[count1]!='\0') count1++;
    while(s2[count2]!='\0') count2++;

    if(count1==count2)
        printf("Possible Anagram");
    else
        printf("Not Anagram");
}
