#include <stdio.h>

int main()
{
    float length, width, area, perimeter;

    printf("Enter length and width: ");
    scanf("%f %f", &length, &width);

    area = length * width;
    perimeter = 2 * (length + width);

    printf("Area = %.2f\n", area);
    printf("Perimeter = %.2f", perimeter);

    return 0;
}

