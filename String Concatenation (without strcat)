#include <stdio.h>

int main()
{
    char s1[50], s2[50];
    int i = 0, j = 0;

    printf("Enter first string: ");
    scanf("%s", s1);

    printf("Enter second string: ");
    scanf("%s", s2);

    while(s1[i] != '\0')
        i++;

    while(s2[j] != '\0')
    {
        s1[i] = s2[j];
        i++;
        j++;
    }

    s1[i] = '\0';

    printf("Concatenated string: %s", s1);

    return 0;
}
