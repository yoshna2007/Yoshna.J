#include<stdio.h>
int main()
{
    int square,num,temp;
    scanf("%d",&num);
    square=num*num;
    temp=num;
    while (temp>0){
        if(temp%10!=square%10){
            printf("not automorphic");
            return 0;
        }
        temp=temp/10;
        square=square/10;
    }
    printf("automorphic");
    return 0;
}
