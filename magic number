#include<stdio.h>
void main()
{
    int digit,sum,temp;
    scanf("%d",&temp);
    while (temp>9){
        sum=0;
        while(temp>0){
        digit=temp%10;
        sum=sum+digit;
        temp=temp/10;
        }
    }
    temp=sum;
    if (temp==1)
    printf("magic number");
    else
    printf("not magic number");
    
}
