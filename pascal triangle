#include <stdio.h>

int main()
{
    int i, j, n, fact = 1;

    printf("Enter number of rows: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        fact = 1;

        for(j = 0; j <= i; j++)
        {
            if(j == 0 || i == 0)
                fact = 1;
            else
                fact = fact * (i - j + 1) / j;

            printf("%d ", fact);
        }

        printf("\n");
    }

    return 0;
}
