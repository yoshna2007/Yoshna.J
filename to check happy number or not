#include <stdio.h>
int main() {
    int num, temp, digit, sum;
    printf("Enter a number: ");
    scanf("%d", &num);
while (num != 1 && num != 4) {
        sum = 0;
while (num > 0) {
            digit = num % 10;
            sum = sum + digit * digit;
            num = num / 10;
        }
 num = sum;
    }
if (num == 1)
        printf("Happy Number");
    else
        printf("Not a Happy Number");
return 0;
}
